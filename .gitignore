# ============================================================
# .gitignore — Danh sách file TUYỆT ĐỐI KHÔNG commit lên Git
# ============================================================

# Terraform state files — chứa toàn bộ thông tin hạ tầng
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# File chứa biến thực — có thể chứa secret
*.tfvars
terraform.tfvars
terraform.tfvars.json
override.tf
override.tf.json

# SSH private keys — KHÔNG BAO GIỜ commit
*.pem
*.key
id_rsa
id_rsa.*
id_ed25519
!id_ed25519.pub

# Plan output
tfplan.out
*.tfplan

# OS files
.DS_Store
Thumbs.db
*.swp
